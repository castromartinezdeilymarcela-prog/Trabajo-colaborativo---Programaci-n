class Reserva(EntidadSistema):
    # Clase que representa una reserva.

    def __init__(self, identificador, cliente, servicio, duracion):
        # Inicializa la entidad reserva.
        super().__init__(identificador)

        # Valida que el cliente sea una instancia válida.
        if not isinstance(cliente, Cliente):
            raise ReservaError("El cliente asociado no es válido.")

        # Valida que el servicio sea una instancia válida.
        if not isinstance(servicio, Servicio):
            raise ReservaError("El servicio asociado no es válido.")

        # Valida duración positiva.
        if duracion <= 0:
            raise ReservaError("La duración debe ser mayor que cero.")

        # Guarda los atributos de la reserva.
        self.cliente = cliente
        self.servicio = servicio
        self.duracion = duracion
        self.estado = "Creada"
        self.costo = 0
        self.fecha_creacion = datetime.now()

    def procesar(self):
        # Procesa la reserva calculando el costo.

        try:
            # Calcula el costo usando descuento e impuesto.
            self.costo = self.servicio.calcular_costo(
                self.duracion,
                descuento=0.05,
                impuesto=0.19
            )

        except CalculoCostoError as error:
            # Cambia el estado si ocurre error.
            self.estado = "Error"

            # Registra error.
            logging.error(f"Error procesando reserva {self.identificador}: {error}")

            # Encadena excepción.
            raise ReservaError("No fue posible procesar la reserva.") from error

        else:
            # Cambia estado si todo sale bien.
            self.estado = "Procesada"

            # Registra evento exitoso.
            logging.info(f"Reserva {self.identificador} procesada correctamente.")

        finally:
            # Se ejecuta siempre.
            logging.info(f"Finalizó intento de procesamiento de reserva {self.identificador}.")

    def confirmar(self):
        # Confirma una reserva procesada.

        try:
            # Valida que la reserva esté procesada.
            if self.estado != "Procesada":
                raise ReservaError("Solo se pueden confirmar reservas procesadas.")

            # Cambia estado.
            self.estado = "Confirmada"

        except ReservaError as error:
            # Registra error.
            logging.error(f"Error confirmando reserva {self.identificador}: {error}")

            # Relanza excepción.
            raise

        else:
            # Registra éxito.
            logging.info(f"Reserva {self.identificador} confirmada correctamente.")

        finally:
            # Registra cierre del intento.
            logging.info(f"Finalizó intento de confirmación de reserva {self.identificador}.")

    def cancelar(self):
        # Cancela una reserva.

        try:
            # Valida si ya estaba cancelada.
            if self.estado == "Cancelada":
                raise ReservaError("La reserva ya se encuentra cancelada.")

            # Cambia estado.
            self.estado = "Cancelada"

        except ReservaError as error:
            # Registra error.
            logging.error(f"Error cancelando reserva {self.identificador}: {error}")

            # Relanza excepción.
            raise

        else:
            # Registra éxito.
            logging.info(f"Reserva {self.identificador} cancelada correctamente.")

        finally:
            # Registra cierre del intento.
            logging.info(f"Finalizó intento de cancelación de reserva {self.identificador}.")

    def mostrar_info(self):
        # Retorna información completa de la reserva.
        return (
            f"{self.identificador} | "
            f"Cliente: {self.cliente.nombre} | "
            f"Documento: {self.cliente.documento} | "
            f"Servicio: {self.servicio.nombre} | "
            f"Duración: {self.duracion} hora(s) | "
            f"Estado: {self.estado} | "
            f"Costo: ${self.costo:,.0f}"
        )


