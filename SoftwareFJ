        lista_frame = ttk.LabelFrame(frame, text="Servicios disponibles", padding=10)
        lista_frame.grid(row=3, column=0, columnspan=2, sticky="nsew", padx=5, pady=10)

        # Configura expansión.
        frame.rowconfigure(3, weight=1)
        frame.columnconfigure(1, weight=1)

        # Listbox servicios.
        self.lista_servicios = tk.Listbox(lista_frame, height=15)
        self.lista_servicios.pack(fill="both", expand=True)

        # Carga servicios.
        self.actualizar_lista_servicios()

    def actualizar_valor_servicio_gui(self):
        # Actualiza el valor base del servicio seleccionado.

        try:
            # Obtiene selección.
            seleccion = self.var_servicio_editar.get()

            # Valida selección.
            if not seleccion:
                raise ServicioNoDisponibleError("Debe seleccionar un servicio.")

            # Obtiene identificador desde el texto del combobox.
            identificador_servicio = seleccion.split(" - ")[0]

            # Convierte nuevo precio.
            try:
                nuevo_precio = float(self.var_nuevo_precio.get())

            except ValueError as error:
                # Encadena error de conversión.
                raise DatoInvalidoError("El nuevo valor debe ser numérico.") from error

            # Edita servicio.
            servicio = self.sistema.editar_valor_servicio(identificador_servicio, nuevo_precio)

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado en GUI al editar servicio: {error}")
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Limpia campo.
            self.var_nuevo_precio.set("")

            # Actualiza lista.
            self.actualizar_lista_servicios()

            # Mensaje.
            messagebox.showinfo(
                "Servicio actualizado",
                f"El valor de {servicio.nombre} fue actualizado correctamente."
            )

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def actualizar_lista_servicios(self):
        # Actualiza visualmente la lista de servicios.

        # Limpia lista.
        self.lista_servicios.delete(0, tk.END)

        # Inserta servicios actuales.
        for servicio in self.sistema.servicios:
            self.lista_servicios.insert(tk.END, servicio.mostrar_info())
            self.lista_servicios.insert(tk.END, f"Descripción: {servicio.describir_servicio()}")
            self.lista_servicios.insert(tk.END, "-" * 100)

