class ReservaSala(Servicio):
    # Servicio especializado para reservar salas.

    def __init__(self, identificador, capacidad, precio_base=50000):
        # Llama al constructor de Servicio.
        super().__init__(identificador, "Reserva de sala", precio_base)

        # Valida la capacidad de la sala.
        if capacidad <= 0:
            # Lanza error si la capacidad es inválida.
            raise DatoInvalidoError("La capacidad de la sala debe ser mayor que cero.")

        # Guarda la capacidad de la sala.
        self.capacidad = capacidad

    def calcular_costo(self, duracion, descuento=0, impuesto=0):
        # Calcula el costo de reservar una sala.

        try:
            # Valida disponibilidad.
            self.validar_disponibilidad()

            # Valida que la duración sea positiva.
            if duracion <= 0:
                # Lanza error si la duración es inválida.
                raise CalculoCostoError("La duración debe ser mayor que cero.")

            # Calcula el costo base.
            costo = self.precio_base * duracion

            # Agrega costo adicional si la sala es grande.
            if self.capacidad > 20:
                # Aplica recargo por capacidad.
                costo += 30000

            # Aplica descuento.
            costo -= costo * descuento

            # Aplica impuesto.
            costo += costo * impuesto

            # Valida que el costo final no sea negativo.
            if costo < 0:
                # Lanza error si el costo es inconsistente.
                raise CalculoCostoError("El costo calculado no puede ser negativo.")

            # Retorna el costo final.
            return costo

        except Exception as error:
            # Registra error en el log.
            logging.error(f"Error calculando costo de sala: {error}")

            # Encadena la excepción.
            raise CalculoCostoError("No fue posible calcular el costo de la sala.") from error

    def describir_servicio(self):
        # Describe el servicio de sala.
        return f"Sala con capacidad para {self.capacidad} personas."


