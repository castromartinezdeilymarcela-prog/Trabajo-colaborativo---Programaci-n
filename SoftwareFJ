class AlquilerEquipo(Servicio):
    # Servicio especializado para alquiler de equipos.

    def __init__(self, identificador, tipo_equipo, precio_base=35000):
        # Llama al constructor de Servicio.
        super().__init__(identificador, "Alquiler de equipo", precio_base)

        # Valida que el tipo de equipo no esté vacío.
        if not tipo_equipo or not tipo_equipo.strip():
            # Lanza error si el tipo de equipo está vacío.
            raise DatoInvalidoError("El tipo de equipo no puede estar vacío.")

        # Guarda el tipo de equipo.
        self.tipo_equipo = tipo_equipo.strip()

    def calcular_costo(self, duracion, descuento=0, impuesto=0):
        # Calcula el costo del alquiler de equipos.

        try:
            # Valida disponibilidad.
            self.validar_disponibilidad()

            # Valida que la duración sea positiva.
            if duracion <= 0:
                # Lanza error si la duración es inválida.
                raise CalculoCostoError("La duración del alquiler debe ser mayor que cero.")

            # Calcula el costo base.
            costo = self.precio_base * duracion

            # Aplica recargo si el equipo es especializado.
            if self.tipo_equipo.lower() in ["servidor", "proyector", "computador"]:
                # Suma recargo por equipo.
                costo += 20000

            # Aplica descuento.
            costo -= costo * descuento

            # Aplica impuesto.
            costo += costo * impuesto

            # Retorna el costo calculado.
            return costo

        except Exception as error:
            # Registra error en el log.
            logging.error(f"Error calculando costo de equipo: {error}")

            # Encadena excepción.
            raise CalculoCostoError("No fue posible calcular el costo del alquiler.") from error

    def describir_servicio(self):
        # Describe el servicio de alquiler.
        return f"Alquiler de equipo tipo: {self.tipo_equipo}."


