# ================================================================
# EXCEPCIONES PERSONALIZADAS DEL SISTEMA
# ================================================================

class SistemaFJError(Exception):
    # Excepción base personalizada para el sistema Software FJ.
    pass


class DatoInvalidoError(SistemaFJError):
    # Excepción para datos inválidos ingresados por el usuario.
    pass


class ClienteInvalidoError(SistemaFJError):
    # Excepción para errores relacionados con clientes.
    pass


class ServicioNoDisponibleError(SistemaFJError):
    # Excepción para servicios no disponibles.
    pass


class ReservaError(SistemaFJError):
    # Excepción para errores relacionados con reservas.
    pass


class CalculoCostoError(SistemaFJError):
    # Excepción para errores en cálculos de costos.
    pass


# ================================================================
# CLASE ABSTRACTA GENERAL DEL SISTEMA
# ================================================================

class EntidadSistema(ABC):
    # Clase abstracta que representa cualquier entidad general del sistema.

    def __init__(self, identificador):
        # Constructor que recibe un identificador.
        if not identificador:
            # Valida que el identificador no esté vacío.
            raise DatoInvalidoError("El identificador no puede estar vacío.")

        # Guarda el identificador como atributo protegido.
        self._identificador = identificador

    @property
    def identificador(self):
        # Devuelve el identificador de la entidad.
        return self._identificador

    @abstractmethod
    def mostrar_info(self):
        # Método abstracto obligatorio para las clases hijas.
        pass


# ================================================================
# CLASE CLIENTE CON ENCAPSULACIÓN Y VALIDACIONES
# ================================================================

class Cliente(EntidadSistema):
    # Clase que representa un cliente de Software FJ.

    def __init__(self, identificador, nombre, documento, telefono, correo):
        # Llama al constructor de la clase padre.
        super().__init__(identificador)

        # Valida y asigna el nombre del cliente.
        self.__nombre = self.__validar_texto(nombre, "nombre")

        # Valida y asigna el documento del cliente.
        self.__documento = self.__validar_documento(documento)

        # Valida y asigna el teléfono del cliente.
        self.__telefono = self.__validar_telefono(telefono)

        # Valida y asigna el correo del cliente.
        self.__correo = self.__validar_correo(correo)

    def __validar_texto(self, valor, campo):
        # Valida que un texto no esté vacío.
        if not valor or not valor.strip():
            # Lanza error si el texto está vacío.
            raise ClienteInvalidoError(f"El campo {campo} no puede estar vacío.")

        # Retorna el texto sin espacios sobrantes.
        return valor.strip()

    def __validar_documento(self, documento):
        # Valida que el documento sea numérico.
        if not documento or not documento.isdigit():
            # Lanza error si el documento no es válido.
            raise ClienteInvalidoError("El documento debe contener solo números.")

        # Valida que el documento tenga longitud suficiente.
        if len(documento) < 5:
            # Lanza error si el documento es demasiado corto.
            raise ClienteInvalidoError("El documento debe tener mínimo 5 dígitos.")

        # Retorna el documento validado.
        return documento

    def __validar_telefono(self, telefono):
        # Valida que el teléfono sea numérico.
        if not telefono or not telefono.isdigit():
            # Lanza error si el teléfono contiene letras o símbolos.
            raise ClienteInvalidoError("El teléfono debe contener solo números.")

        # Valida longitud mínima del teléfono.
        if len(telefono) < 7:
            # Lanza error si el teléfono es muy corto.
            raise ClienteInvalidoError("El teléfono debe tener mínimo 7 dígitos.")

        # Retorna el teléfono validado.
        return telefono

    def __validar_correo(self, correo):
        # Valida que el correo tenga estructura básica.
        if not correo or "@" not in correo or "." not in correo:
            # Lanza error si el correo no es válido.
            raise ClienteInvalidoError("El correo electrónico no es válido.")

        # Retorna el correo en minúsculas.
        return correo.strip().lower()

    @property
    def nombre(self):
        # Retorna el nombre del cliente.
        return self.__nombre

    @property
    def documento(self):
        # Retorna el documento del cliente.
        return self.__documento

    @property
    def telefono(self):
        # Retorna el teléfono del cliente.
        return self.__telefono

    @property
    def correo(self):
        # Retorna el correo del cliente.
        return self.__correo

    def mostrar_info(self):
        # Devuelve la información del cliente en texto.
        return f"{self.nombre} | Documento: {self.documento} | Tel: {self.telefono} | Email: {self.correo}"


