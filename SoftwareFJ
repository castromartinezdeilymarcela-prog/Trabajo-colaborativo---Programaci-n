            reserva.cancelar()

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado cancelando reserva desde GUI: {error}")
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Actualiza lista.
            self.actualizar_lista_reservas()

            # Mensaje.
            messagebox.showinfo("Éxito", "Reserva cancelada correctamente.")

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def actualizar_lista_reservas(self):
