# CONTROLADOR DEL SISTEMA
# ==========================================================================

class SistemaSoftwareFJ:
    # Clase controladora que administra clientes, servicios y reservas.

    def __init__(self):
        # Lista interna de clientes.
        self.clientes = []

        # Lista interna de servicios.
        self.servicios = []

        # Lista interna de reservas.
        self.reservas = []

        # Carga servicios iniciales.
        self.cargar_servicios_iniciales()

    def cargar_servicios_iniciales(self):
        # Crea los servicios iniciales del sistema.

        try:
            self.servicios.append(ReservaSala("S1", capacidad=25, precio_base=50000))
            self.servicios.append(AlquilerEquipo("S2", tipo_equipo="Computador", precio_base=35000))
            self.servicios.append(AsesoriaEspecializada("S3", area="Software", precio_base=80000))

        except SistemaFJError as error:
            logging.error(f"Error cargando servicios iniciales: {error}")

    def agregar_cliente(self, nombre, documento, telefono, correo):
        # Agrega un cliente nuevo.

        try:
            # Genera identificador automático.
            identificador = f"C{len(self.clientes) + 1}"

            # Crea cliente con validaciones.
            cliente = Cliente(identificador, nombre, documento, telefono, correo)

            # Valida que el documento no esté duplicado.
            for cliente_existente in self.clientes:
                if cliente_existente.documento == cliente.documento:
                    raise ClienteInvalidoError("Ya existe un cliente con ese documento.")

            # Agrega cliente a la lista.
            self.clientes.append(cliente)

        except ClienteInvalidoError as error:
            logging.error(f"Error agregando cliente: {error}")
            raise

        except Exception as error:
            logging.error(f"Error inesperado agregando cliente: {error}")
            raise SistemaFJError("No fue posible agregar el cliente.") from error

        else:
            logging.info(f"Cliente agregado correctamente: {cliente.mostrar_info()}")
            return cliente

        finally:
            logging.info("Finalizó intento de agregar cliente.")

    def editar_cliente(self, documento_actual, nuevo_nombre, nuevo_documento, nuevo_telefono, nuevo_correo):
        # Edita los datos de un cliente existente.

        try:
            # Inicializa variable de búsqueda.
            cliente_encontrado = None

            # Busca cliente por documento actual.
            for cliente in self.clientes:
                if cliente.documento == documento_actual:
                    cliente_encontrado = cliente

            # Valida existencia del cliente.
            if cliente_encontrado is None:
                raise ClienteInvalidoError("No se encontró el cliente que desea editar.")

            # Valida que el nuevo documento no pertenezca a otro cliente.
            for cliente in self.clientes:
                if cliente.documento == nuevo_documento and cliente.documento != documento_actual:
                    raise ClienteInvalidoError("Ya existe otro cliente con ese documento.")

            # Crea cliente temporal para reutilizar validaciones.
            cliente_editado = Cliente(
                cliente_encontrado.identificador,
                nuevo_nombre,
                nuevo_documento,
                nuevo_telefono,
                nuevo_correo
            )

            # Reemplaza cliente anterior por cliente editado.
            indice = self.clientes.index(cliente_encontrado)
            self.clientes[indice] = cliente_editado

            # Actualiza referencias del cliente en reservas ya creadas.
            for reserva in self.reservas:
                if reserva.cliente.documento == documento_actual:
                    reserva.cliente = cliente_editado

        except ClienteInvalidoError as error:
            logging.error(f"Error editando cliente: {error}")
            raise

        except Exception as error:
            logging.error(f"Error inesperado editando cliente: {error}")
            raise SistemaFJError("No fue posible editar el cliente.") from error

        else:
            logging.info(f"Cliente editado correctamente: {cliente_editado.mostrar_info()}")
            return cliente_editado

        finally:
            logging.info("Finalizó intento de editar cliente.")

    def eliminar_cliente(self, documento):
        # Elimina un cliente registrado.

        try:
            # Inicializa variable de búsqueda.
            cliente_encontrado = None

            # Busca cliente por documento.
            for cliente in self.clientes:
                if cliente.documento == documento:
                    cliente_encontrado = cliente

            # Valida existencia.
            if cliente_encontrado is None:
                raise ClienteInvalidoError("No se encontró el cliente que desea eliminar.")

            # Evita eliminar clientes con reservas registradas.
            for reserva in self.reservas:
                if reserva.cliente.documento == documento:
                    raise ClienteInvalidoError(
                        "No se puede eliminar el cliente porque tiene reservas registradas."
                    )

            # Elimina cliente.
            self.clientes.remove(cliente_encontrado)

        except ClienteInvalidoError as error:
            logging.error(f"Error eliminando cliente: {error}")
            raise

        except Exception as error:
            logging.error(f"Error inesperado eliminando cliente: {error}")
            raise SistemaFJError("No fue posible eliminar el cliente.") from error

        else:
            logging.info(f"Cliente eliminado correctamente: {cliente_encontrado.mostrar_info()}")
            return cliente_encontrado

        finally:
            logging.info("Finalizó intento de eliminar cliente.")

    def obtener_cliente_por_documento(self, documento):
        # Busca un cliente por documento.

        for cliente in self.clientes:
            if cliente.documento == documento:
                return cliente

        raise ClienteInvalidoError("No se encontró un cliente con ese documento.")

    def crear_reserva(self, cliente, servicio, duracion):
        # Crea y procesa una reserva.

        try:
            # Genera identificador automático.
            identificador = f"R{len(self.reservas) + 1}"

            # Crea reserva.
            reserva = Reserva(identificador, cliente, servicio, duracion)

            # Procesa reserva para calcular costo.
            reserva.procesar()

            # Agrega reserva a la lista interna.
            self.reservas.append(reserva)

        except ReservaError as error:
            logging.error(f"Error creando reserva: {error}")
            raise

        except Exception as error:
            logging.error(f"Error inesperado creando reserva: {error}")
            raise SistemaFJError("No fue posible crear la reserva.") from error

        else:
            logging.info(f"Reserva creada correctamente: {reserva.mostrar_info()}")
            return reserva

        finally:
            logging.info("Finalizó intento de crear reserva.")

    def editar_valor_servicio(self, identificador_servicio, nuevo_precio):
        # Edita el precio base de un servicio.

        try:
            # Valida el precio.
            if nuevo_precio <= 0:
                raise DatoInvalidoError("El valor del servicio debe ser mayor que cero.")

            # Busca servicio por identificador.
            for servicio in self.servicios:
                if servicio.identificador == identificador_servicio:
                    precio_anterior = servicio.precio_base
                    servicio.precio_base = nuevo_precio

                    logging.info(
                        f"Valor de servicio actualizado: "
                        f"{servicio.nombre} pasó de ${precio_anterior:,.0f} "
                        f"a ${nuevo_precio:,.0f}"
                    )

                    return servicio

            # Lanza error si no encuentra el servicio.
            raise ServicioNoDisponibleError("No se encontró el servicio seleccionado.")

        except SistemaFJError as error:
            logging.error(f"Error editando valor del servicio: {error}")
            raise

        except Exception as error:
            logging.error(f"Error inesperado editando servicio: {error}")
            raise SistemaFJError("No fue posible editar el valor del servicio.") from error

        finally:
            logging.info("Finalizó intento de editar valor de servicio.")


