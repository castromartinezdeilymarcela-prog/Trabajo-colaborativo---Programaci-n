class SistemaSoftwareFJ:
    # Clase que administra clientes, servicios y reservas en listas internas.

    def __init__(self):
        # Lista interna de clientes.
        self.clientes = []

        # Lista interna de servicios.
        self.servicios = []

        # Lista interna de reservas.
        self.reservas = []

        # Carga servicios iniciales.
        self.cargar_servicios_iniciales()

    def cargar_servicios_iniciales(self):
        # Crea servicios iniciales disponibles para el sistema.

        try:
            # Agrega servicio de sala.
            self.servicios.append(ReservaSala("S1", capacidad=25))

            # Agrega servicio de alquiler.
            self.servicios.append(AlquilerEquipo("S2", tipo_equipo="Computador"))

            # Agrega servicio de asesoría.
            self.servicios.append(AsesoriaEspecializada("S3", area="Software"))

        except SistemaFJError as error:
            # Registra errores al cargar servicios.
            logging.error(f"Error cargando servicios iniciales: {error}")

    def agregar_cliente(self, nombre, documento, telefono, correo):
        # Agrega un cliente nuevo al sistema.

        try:
            # Genera identificador automático.
            identificador = f"C{len(self.clientes) + 1}"

            # Crea el cliente.
            cliente = Cliente(identificador, nombre, documento, telefono, correo)

            # Verifica que el documento no esté repetido.
            for cliente_existente in self.clientes:
                # Compara documentos.
                if cliente_existente.documento == cliente.documento:
                    # Lanza error si ya existe.
                    raise ClienteInvalidoError("Ya existe un cliente con ese documento.")

            # Agrega cliente a la lista interna.
            self.clientes.append(cliente)

        except ClienteInvalidoError as error:
            # Registra error de cliente.
            logging.error(f"Error agregando cliente: {error}")

            # Relanza error.
            raise

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado agregando cliente: {error}")

            # Encadena excepción.
            raise SistemaFJError("No fue posible agregar el cliente.") from error

        else:
            # Registra evento exitoso.
            logging.info(f"Cliente agregado correctamente: {cliente.mostrar_info()}")

            # Retorna cliente creado.
            return cliente

        finally:
            # Registra finalización del intento.
            logging.info("Finalizó intento de agregar cliente.")

    def crear_reserva(self, cliente, servicio, duracion):
        # Crea una reserva y la almacena.

        try:
            # Genera identificador automático.
            identificador = f"R{len(self.reservas) + 1}"

            # Crea reserva.
            reserva = Reserva(identificador, cliente, servicio, duracion)

            # Procesa reserva para calcular costo.
            reserva.procesar()

            # Agrega reserva a la lista.
            self.reservas.append(reserva)

        except ReservaError as error:
            # Registra error de reserva.
            logging.error(f"Error creando reserva: {error}")

            # Relanza error.
            raise

        except Exception as error:
            # Registra error general.
            logging.error(f"Error inesperado creando reserva: {error}")

            # Encadena excepción.
            raise SistemaFJError("No fue posible crear la reserva.") from error

        else:
            # Registra creación exitosa.
            logging.info(f"Reserva creada correctamente: {reserva.mostrar_info()}")

            # Retorna reserva.
            return reserva

        finally:
            # Registra finalización.
            logging.info("Finalizó intento de crear reserva.")

    def obtener_cliente_por_documento(self, documento):
        # Busca un cliente por documento.

        for cliente in self.clientes:
            # Compara el documento del cliente.
            if cliente.documento == documento:
                # Retorna cliente encontrado.
                return cliente

        # Lanza error si no se encuentra.
        raise ClienteInvalidoError("No se encontró un cliente con ese documento.")

    def generar_10_simulaciones(self):
        # Genera 10 simulaciones del sistema para probar logs.

        # Lista para guardar resultados.
        resultados = []

        # Datos de prueba.
        datos_clientes = [
            ("Ana Torres", "12345678", "3101234567", "ana@email.com"),
            ("Luis Pérez", "87654321", "3207654321", "luis@email.com"),
            ("", "11111", "3001234567", "correo@email.com"),
            ("Carlos Mora", "abc123", "3009876543", "carlos@email.com"),
            ("María Rojas", "22222222", "123", "maria@email.com"),
            ("Pedro Gómez", "33333333", "3152223333", "correo_invalido"),
            ("Laura Díaz", "44444444", "3163334444", "laura@email.com"),
            ("Juan Castro", "55555555", "3174445555", "juan@email.com"),
            ("Sofía Peña", "66666666", "3185556666", "sofia@email.com"),
            ("Andrés Ruiz", "77777777", "3196667777", "andres@email.com")
        ]

        # Ejecuta 10 simulaciones.
        for i in range(10):
            # Inicia control de errores por simulación.
            try:
                # Obtiene datos del cliente.
                nombre, documento, telefono, correo = datos_clientes[i]

                # Intenta agregar cliente.
