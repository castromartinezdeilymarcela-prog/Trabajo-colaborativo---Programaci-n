    def crear_pestana_servicios(self):
        # Crea frame principal para editar servicios.
        frame = ttk.LabelFrame(self.frame_servicios, text="Editar valor base de servicios", padding=10)
        frame.pack(fill="both", expand=True, padx=10, pady=10)

