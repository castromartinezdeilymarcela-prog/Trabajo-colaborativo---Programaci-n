# ==========================================================================
# EXCEPCIONES PERSONALIZADAS
# ==========================================================================

class SistemaFJError(Exception):
    # Excepción base del sistema Software FJ.
    pass


class DatoInvalidoError(SistemaFJError):
    # Excepción para datos inválidos.
    pass


class ClienteInvalidoError(SistemaFJError):
    # Excepción para errores relacionados con clientes.
    pass


class ServicioNoDisponibleError(SistemaFJError):
    # Excepción para servicios no disponibles.
    pass


class ReservaError(SistemaFJError):
    # Excepción para errores relacionados con reservas.
    pass


class CalculoCostoError(SistemaFJError):
    # Excepción para errores en cálculos de costos.
    pass


# ==========================================================================
# CLASE ABSTRACTA GENERAL DEL SISTEMA
# ==========================================================================

class EntidadSistema(ABC):
    # Clase abstracta que representa una entidad general del sistema.

    def __init__(self, identificador):
        # Valida que el identificador no esté vacío.
        if not identificador:
            raise DatoInvalidoError("El identificador no puede estar vacío.")

        # Guarda el identificador como atributo protegido.
        self._identificador = identificador

    @property
    def identificador(self):
        # Retorna el identificador de la entidad.
        return self._identificador

    @abstractmethod
    def mostrar_info(self):
        # Método abstracto obligatorio para las clases derivadas.
        pass


# ==========================================================================
# CLASE CLIENTE CON ENCAPSULACIÓN Y VALIDACIONES
# ==========================================================================

class Cliente(EntidadSistema):
    # Clase que representa un cliente de Software FJ.

    def __init__(self, identificador, nombre, documento, telefono, correo):
        # Llama al constructor de la clase abstracta padre.
        super().__init__(identificador)

        # Valida y asigna los datos privados del cliente.
        self.__nombre = self.__validar_texto(nombre, "nombre")
        self.__documento = self.__validar_documento(documento)
        self.__telefono = self.__validar_telefono(telefono)
        self.__correo = self.__validar_correo(correo)

    def __validar_texto(self, valor, campo):
        # Valida que un campo de texto no esté vacío.
        if not valor or not valor.strip():
            raise ClienteInvalidoError(f"El campo {campo} no puede estar vacío.")

        # Retorna el texto sin espacios al inicio o final.
        return valor.strip()

    def __validar_documento(self, documento):
        # Valida que el documento contenga solo números.
        if not documento or not documento.isdigit():
            raise ClienteInvalidoError("El documento debe contener solo números.")

        # Valida longitud mínima del documento.
        if len(documento) < 5:
            raise ClienteInvalidoError("El documento debe tener mínimo 5 dígitos.")

        # Retorna documento validado.
        return documento

    def __validar_telefono(self, telefono):
        # Valida que el teléfono contenga solo números.
        if not telefono or not telefono.isdigit():
            raise ClienteInvalidoError("El teléfono debe contener solo números.")

        # Valida longitud mínima del teléfono.
        if len(telefono) < 7:
            raise ClienteInvalidoError("El teléfono debe tener mínimo 7 dígitos.")

        # Retorna teléfono validado.
        return telefono

    def __validar_correo(self, correo):
        # Valida una estructura básica de correo electrónico.
        if not correo or "@" not in correo or "." not in correo:
            raise ClienteInvalidoError("El correo electrónico no es válido.")

        # Retorna correo limpio y en minúscula.
        return correo.strip().lower()

    @property
    def nombre(self):
        # Retorna el nombre del cliente.
        return self.__nombre

    @property
    def documento(self):
        # Retorna el documento del cliente.
        return self.__documento

    @property
    def telefono(self):
        # Retorna el teléfono del cliente.
        return self.__telefono

    @property
    def correo(self):
        # Retorna el correo del cliente.
        return self.__correo

    def mostrar_info(self):
        # Retorna información del cliente en formato legible.
        return (
            f"{self.identificador} | "
            f"{self.nombre} | "
            f"Documento: {self.documento} | "
            f"Teléfono: {self.telefono} | "
            f"Correo: {self.correo}"
        )


# ==========================================================================
# CLASE ABSTRACTA SERVICIO
# ==========================================================================

class Servicio(EntidadSistema):
    # Clase abstracta que representa un servicio general.

    def __init__(self, identificador, nombre, precio_base, disponible=True):
        # Llama al constructor de la clase padre.
        super().__init__(identificador)

        # Valida el nombre del servicio.
        if not nombre or not nombre.strip():
            raise DatoInvalidoError("El nombre del servicio no puede estar vacío.")

        # Valida que el precio base sea positivo.
        if precio_base <= 0:
            raise DatoInvalidoError("El precio base debe ser mayor que cero.")

        # Guarda atributos protegidos.
        self._nombre = nombre.strip()
        self._precio_base = precio_base
        self._disponible = disponible

    @property
    def nombre(self):
        # Retorna el nombre del servicio.
        return self._nombre

    @property
    def precio_base(self):
        # Retorna el precio base del servicio.
        return self._precio_base

    @precio_base.setter
    def precio_base(self, nuevo_precio):
        # Permite editar el precio base con validación.
        if nuevo_precio <= 0:
            raise DatoInvalidoError("El nuevo precio debe ser mayor que cero.")

        self._precio_base = nuevo_precio

    @property
    def disponible(self):
        # Retorna la disponibilidad del servicio.
        return self._disponible

    def validar_disponibilidad(self):
        # Valida que el servicio esté disponible.
        if not self._disponible:
            raise ServicioNoDisponibleError(f"El servicio {self.nombre} no está disponible.")

    @abstractmethod
    def calcular_costo(self, duracion, descuento=0, impuesto=0):
        # Método abstracto para calcular el costo del servicio.
        pass

    @abstractmethod
    def describir_servicio(self):
        # Método abstracto para describir el servicio.
        pass

    def mostrar_info(self):
        # Retorna información general del servicio.
        estado = "Disponible" if self.disponible else "No disponible"

        return (
            f"{self.identificador} | "
            f"{self.nombre} | "
            f"Precio base: ${self.precio_base:,.0f} | "
            f"Estado: {estado}"
        )


# ==========================================================================
# SERVICIO 1: RESERVA DE SALAS
# ==========================================================================

class ReservaSala(Servicio):
    # Servicio especializado para reservas de salas.

    def __init__(self, identificador, capacidad, precio_base=50000):
        # Inicializa el servicio de reserva de sala.
        super().__init__(identificador, "Reserva de sala", precio_base)

        # Valida que la capacidad sea positiva.
        if capacidad <= 0:
            raise DatoInvalidoError("La capacidad debe ser mayor que cero.")

        # Guarda la capacidad de la sala.
        self.capacidad = capacidad

    def calcular_costo(self, duracion, descuento=0, impuesto=0):
        # Calcula el costo total de la reserva de sala.

        try:
            # Valida disponibilidad.
            self.validar_disponibilidad()

            # Valida duración positiva.
            if duracion <= 0:
                raise CalculoCostoError("La duración debe ser mayor que cero.")

            # Calcula costo base según duración.
            costo = self.precio_base * duracion

            # Aplica recargo si la sala tiene capacidad superior a 20 personas.
            if self.capacidad > 20:
                costo += 30000

            # Aplica descuento.
            costo -= costo * descuento

            # Aplica impuesto.
            costo += costo * impuesto

            # Valida que el costo no sea negativo.
            if costo < 0:
                raise CalculoCostoError("El costo calculado no puede ser negativo.")

            return costo

        except Exception as error:
            # Registra el error en el archivo .txt.
            logging.error(f"Error calculando costo de sala: {error}")

            # Encadena la excepción.
            raise CalculoCostoError("No fue posible calcular el costo de la sala.") from error

    def describir_servicio(self):
        # Describe el servicio de reserva de sala.
        return f"Sala con capacidad para {self.capacidad} personas."


