class Servicio(EntidadSistema):
    # Clase abstracta que representa un servicio general.

    def __init__(self, identificador, nombre, precio_base, disponible=True):
        # Llama al constructor de la clase padre.
        super().__init__(identificador)

        # Valida que el nombre no esté vacío.
        if not nombre or not nombre.strip():
            # Lanza error si el nombre está vacío.
            raise DatoInvalidoError("El nombre del servicio no puede estar vacío.")

        # Valida que el precio base sea positivo.
        if precio_base <= 0:
            # Lanza error si el precio no es válido.
            raise DatoInvalidoError("El precio base debe ser mayor que cero.")

        # Guarda el nombre del servicio.
        self._nombre = nombre.strip()

        # Guarda el precio base del servicio.
        self._precio_base = precio_base

        # Guarda el estado de disponibilidad.
        self._disponible = disponible

    @property
    def nombre(self):
        # Retorna el nombre del servicio.
        return self._nombre

    @property
    def precio_base(self):
        # Retorna el precio base del servicio.
        return self._precio_base

    @property
    def disponible(self):
        # Retorna si el servicio está disponible.
        return self._disponible

    def validar_disponibilidad(self):
        # Valida que el servicio esté disponible.
        if not self._disponible:
            # Lanza error si el servicio no está disponible.
            raise ServicioNoDisponibleError(f"El servicio {self.nombre} no está disponible.")

    @abstractmethod
    def calcular_costo(self, duracion, descuento=0, impuesto=0):
        # Método abstracto para calcular costo.
        pass

    @abstractmethod
    def describir_servicio(self):
        # Método abstracto para describir el servicio.
        pass

    def mostrar_info(self):
        # Devuelve información general del servicio.
        estado = "Disponible" if self.disponible else "No disponible"
        return f"{self.nombre} | Precio base: ${self.precio_base:,.0f} | Estado: {estado}"


