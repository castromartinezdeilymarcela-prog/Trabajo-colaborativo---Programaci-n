            except Exception as error:
                # Registra error inesperado.
                mensaje = f"Simulación {i + 1}: ERROR INESPERADO - {error}"

                # Guarda mensaje en resultados.
                resultados.append(mensaje)

                # Registra en log.
                logging.error(mensaje)

            else:
                # Mensaje de simulación exitosa.
                mensaje = f"Simulación {i + 1}: Correcta - {reserva.mostrar_info()}"

                # Guarda mensaje.
                resultados.append(mensaje)

                # Registra evento exitoso.
                logging.info(mensaje)

            finally:
                # Registra cierre de simulación.
                logging.info(f"Finalizó simulación {i + 1}.")

        # Retorna resultados.
        return resultados


# ================================================================
# INTERFAZ GRÁFICA CON TKINTER
# ================================================================

class AplicacionTkinter:
    # Clase encargada de crear y controlar la interfaz gráfica.

    def __init__(self, ventana):
        # Guarda la ventana principal.
        self.ventana = ventana

        # Crea una instancia del sistema.
        self.sistema = SistemaSoftwareFJ()

        # Configura el título de la ventana.
        self.ventana.title("Software FJ - Gestión de Clientes, Servicios y Reservas")

        # Configura el tamaño de la ventana.
        self.ventana.geometry("1050x720")

        # Evita que la ventana sea demasiado pequeña.
        self.ventana.minsize(950, 650)

        # Crea los componentes visuales.
        self.crear_interfaz()

    def crear_interfaz(self):
        # Crea el contenedor principal.
        contenedor = ttk.Frame(self.ventana, padding=10)

        # Ubica el contenedor principal.
        contenedor.pack(fill="both", expand=True)

        # Crea título principal.
        titulo = ttk.Label(
            contenedor,
            text="Sistema Integral de Gestión - Software FJ",
            font=("Arial", 18, "bold")
        )

        # Ubica el título.
        titulo.pack(pady=10)

        # Crea notebook para pestañas.
        self.notebook = ttk.Notebook(contenedor)

        # Ubica el notebook.
        self.notebook.pack(fill="both", expand=True)

        # Crea pestañas.
        self.frame_clientes = ttk.Frame(self.notebook)
        self.frame_reservas = ttk.Frame(self.notebook)
        self.frame_simulaciones = ttk.Frame(self.notebook)
        self.frame_logs = ttk.Frame(self.notebook)

        # Agrega pestañas al notebook.
        self.notebook.add(self.frame_clientes, text="Clientes")
        self.notebook.add(self.frame_reservas, text="Reservas")
        self.notebook.add(self.frame_simulaciones, text="Simulaciones")
        self.notebook.add(self.frame_logs, text="Logs")

        # Construye cada pestaña.
        self.crear_pestana_clientes()
        self.crear_pestana_reservas()
        self.crear_pestana_simulaciones()
        self.crear_pestana_logs()

    def crear_pestana_clientes(self):
        # Crea marco del formulario.
        formulario = ttk.LabelFrame(self.frame_clientes, text="Registrar cliente", padding=10)

        # Ubica el formulario.
        formulario.pack(fill="x", padx=10, pady=10)

        # Crea variables de entrada.
        self.var_nombre = tk.StringVar()
        self.var_documento = tk.StringVar()
        self.var_telefono = tk.StringVar()
        self.var_correo = tk.StringVar()

        # Crea etiquetas y campos.
        ttk.Label(formulario, text="Nombre:").grid(row=0, column=0, sticky="w", padx=5, pady=5)
        ttk.Entry(formulario, textvariable=self.var_nombre, width=35).grid(row=0, column=1, padx=5, pady=5)

        ttk.Label(formulario, text="Documento:").grid(row=1, column=0, sticky="w", padx=5, pady=5)
        ttk.Entry(formulario, textvariable=self.var_documento, width=35).grid(row=1, column=1, padx=5, pady=5)

        ttk.Label(formulario, text="Teléfono:").grid(row=2, column=0, sticky="w", padx=5, pady=5)
        ttk.Entry(formulario, textvariable=self.var_telefono, width=35).grid(row=2, column=1, padx=5, pady=5)

        ttk.Label(formulario, text="Correo:").grid(row=3, column=0, sticky="w", padx=5, pady=5)
        ttk.Entry(formulario, textvariable=self.var_correo, width=35).grid(row=3, column=1, padx=5, pady=5)

        # Botón para agregar cliente.
        ttk.Button(formulario, text="Agregar cliente", command=self.agregar_cliente_gui).grid(
            row=4, column=0, columnspan=2, pady=10
        )

        # Lista de clientes.
        lista_frame = ttk.LabelFrame(self.frame_clientes, text="Clientes registrados", padding=10)

        # Ubica la lista.
        lista_frame.pack(fill="both", expand=True, padx=10, pady=10)

        # Crea Listbox de clientes.
        self.lista_clientes = tk.Listbox(lista_frame, height=12)

        # Ubica Listbox.
        self.lista_clientes.pack(fill="both", expand=True)

    def crear_pestana_reservas(self):
        # Crea marco del formulario de reservas.
        formulario = ttk.LabelFrame(self.frame_reservas, text="Crear reserva", padding=10)

        # Ubica formulario.
        formulario.pack(fill="x", padx=10, pady=10)

        # Variables de reserva.
        self.var_doc_reserva = tk.StringVar()
        self.var_servicio = tk.StringVar()
        self.var_duracion = tk.StringVar()

        # Etiqueta y entrada de documento.
        ttk.Label(formulario, text="Documento cliente:").grid(row=0, column=0, sticky="w", padx=5, pady=5)
        ttk.Entry(formulario, textvariable=self.var_doc_reserva, width=35).grid(row=0, column=1, padx=5, pady=5)

        # Etiqueta de servicio.
        ttk.Label(formulario, text="Servicio:").grid(row=1, column=0, sticky="w", padx=5, pady=5)

        # Lista de nombres de servicios.
        nombres_servicios = [servicio.nombre for servicio in self.sistema.servicios]

        # Combobox de servicios.
        self.combo_servicio = ttk.Combobox(
            formulario,
            textvariable=self.var_servicio,
            values=nombres_servicios,
            state="readonly",
            width=32
        )

        # Ubica combobox.
        self.combo_servicio.grid(row=1, column=1, padx=5, pady=5)

        # Selecciona primer servicio por defecto.
        if nombres_servicios:
            self.combo_servicio.current(0)

        # Entrada de duración.
        ttk.Label(formulario, text="Duración en horas:").grid(row=2, column=0, sticky="w", padx=5, pady=5)
        ttk.Entry(formulario, textvariable=self.var_duracion, width=35).grid(row=2, column=1, padx=5, pady=5)

        # Botón crear reserva.
        ttk.Button(formulario, text="Crear reserva", command=self.crear_reserva_gui).grid(
            row=3, column=0, columnspan=2, pady=10
        )

        # Marco de reservas.
        lista_frame = ttk.LabelFrame(self.frame_reservas, text="Reservas registradas", padding=10)

        # Ubica marco.
        lista_frame.pack(fill="both", expand=True, padx=10, pady=10)

        # Lista de reservas.
        self.lista_reservas = tk.Listbox(lista_frame, height=12)

        # Ubica lista.
        self.lista_reservas.pack(fill="both", expand=True)

        # Marco de botones.
        botones_frame = ttk.Frame(self.frame_reservas)

        # Ubica botones.
        botones_frame.pack(fill="x", padx=10, pady=5)

        # Botón confirmar.
        ttk.Button(botones_frame, text="Confirmar reserva seleccionada", command=self.confirmar_reserva_gui).pack(
            side="left", padx=5
        )

        # Botón cancelar.
        ttk.Button(botones_frame, text="Cancelar reserva seleccionada", command=self.cancelar_reserva_gui).pack(
            side="left", padx=5
        )

    def crear_pestana_simulaciones(self):
        # Crea marco para simulaciones.
        frame = ttk.LabelFrame(self.frame_simulaciones, text="Prueba automática del sistema", padding=10)

        # Ubica marco.
        frame.pack(fill="both", expand=True, padx=10, pady=10)

        # Texto descriptivo.
        descripcion = ttk.Label(
            frame,
            text="Este botón ejecuta 10 simulaciones automáticas con casos válidos e inválidos.\n"
                 "Cada evento y error queda registrado en el archivo software_fj.log.",
            font=("Arial", 11)
        )

        # Ubica descripción.
        descripcion.pack(pady=10)

        # Botón de simulaciones.
        ttk.Button(frame, text="Ejecutar 10 simulaciones", command=self.ejecutar_simulaciones_gui).pack(pady=10)

        # Área de resultados.
        self.texto_simulaciones = tk.Text(frame, height=22, wrap="word")

        # Ubica área de resultados.
        self.texto_simulaciones.pack(fill="both", expand=True, pady=10)

    def crear_pestana_logs(self):
        # Crea marco de logs.
        frame = ttk.LabelFrame(self.frame_logs, text="Archivo de logs", padding=10)

        # Ubica marco.
        frame.pack(fill="both", expand=True, padx=10, pady=10)

        # Botón cargar logs.
        ttk.Button(frame, text="Actualizar logs", command=self.cargar_logs_gui).pack(pady=5)

        # Área de texto de logs.
        self.texto_logs = tk.Text(frame, height=30, wrap="word")

        # Ubica área de texto.
        self.texto_logs.pack(fill="both", expand=True)

    def agregar_cliente_gui(self):
        # Método conectado al botón de agregar cliente.

        try:
            # Obtiene valores del formulario.
            nombre = self.var_nombre.get()
            documento = self.var_documento.get()
            telefono = self.var_telefono.get()
            correo = self.var_correo.get()

            # Agrega cliente usando el sistema.
            cliente = self.sistema.agregar_cliente(nombre, documento, telefono, correo)

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado en interfaz al agregar cliente: {error}")

            # Muestra mensaje.
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Agrega cliente a la lista visual.
            self.lista_clientes.insert(tk.END, cliente.mostrar_info())

            # Limpia campos.
            self.var_nombre.set("")
            self.var_documento.set("")
            self.var_telefono.set("")
            self.var_correo.set("")

            # Muestra confirmación.
            messagebox.showinfo("Éxito", "Cliente agregado correctamente.")

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def crear_reserva_gui(self):
        # Método conectado al botón de crear reserva.

        try:
            # Obtiene documento.
            documento = self.var_doc_reserva.get()

            # Obtiene nombre del servicio.
            nombre_servicio = self.var_servicio.get()

            # Convierte duración a entero.
            try:
                duracion = int(self.var_duracion.get())
            except ValueError as error:
                # Encadena error de conversión.
                raise ReservaError("La duración debe ser un número entero.") from error

            # Busca cliente por documento.
            cliente = self.sistema.obtener_cliente_por_documento(documento)

            # Busca servicio seleccionado.
            servicio = None

            # Recorre servicios disponibles.
            for item in self.sistema.servicios:
                # Compara nombre.
                if item.nombre == nombre_servicio:
                    # Asigna servicio.
                    servicio = item

            # Valida que exista servicio.
            if servicio is None:
                # Lanza error.
                raise ServicioNoDisponibleError("Debe seleccionar un servicio válido.")

            # Crea reserva.
            reserva = self.sistema.crear_reserva(cliente, servicio, duracion)

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado en interfaz al crear reserva: {error}")

            # Muestra error inesperado.
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Inserta reserva en la lista visual.
            self.lista_reservas.insert(tk.END, reserva.mostrar_info())

            # Limpia campos.
            self.var_doc_reserva.set("")
            self.var_duracion.set("")

            # Muestra éxito.
            messagebox.showinfo("Éxito", "Reserva creada correctamente.")

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def confirmar_reserva_gui(self):
        # Confirma la reserva seleccionada.

        try:
            # Obtiene índice seleccionado.
            seleccion = self.lista_reservas.curselection()

            # Valida que exista selección.
            if not seleccion:
                # Lanza error si no hay selección.
                raise ReservaError("Debe seleccionar una reserva.")

            # Obtiene índice.
            indice = seleccion[0]

            # Obtiene reserva.
            reserva = self.sistema.reservas[indice]

            # Confirma reserva.
            reserva.confirmar()

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado confirmando reserva desde GUI: {error}")

            # Muestra error.
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Actualiza texto en lista.
            self.lista_reservas.delete(indice)
            self.lista_reservas.insert(indice, reserva.mostrar_info())

            # Muestra mensaje.
            messagebox.showinfo("Éxito", "Reserva confirmada correctamente.")

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def cancelar_reserva_gui(self):
        # Cancela la reserva seleccionada.

        try:
            # Obtiene selección.
            seleccion = self.lista_reservas.curselection()

            # Valida selección.
            if not seleccion:
                # Lanza error.
                raise ReservaError("Debe seleccionar una reserva.")

            # Obtiene índice.
            indice = seleccion[0]

            # Obtiene reserva.
            reserva = self.sistema.reservas[indice]

            # Cancela reserva.
            reserva.cancelar()

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado cancelando reserva desde GUI: {error}")

            # Muestra error.
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Actualiza lista.
            self.lista_reservas.delete(indice)
            self.lista_reservas.insert(indice, reserva.mostrar_info())

            # Muestra mensaje.
            messagebox.showinfo("Éxito", "Reserva cancelada correctamente.")

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def ejecutar_simulaciones_gui(self):
        # Ejecuta 10 simulaciones desde la interfaz.

        try:
            # Ejecuta simulaciones.
            resultados = self.sistema.generar_10_simulaciones()

            # Limpia área de texto.
            self.texto_simulaciones.delete("1.0", tk.END)

            # Inserta resultados.
            for resultado in resultados:
                # Escribe cada resultado.
                self.texto_simulaciones.insert(tk.END, resultado + "\n\n")

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error ejecutando simulaciones desde GUI: {error}")

            # Muestra error.
            messagebox.showerror("Error", str(error))

        else:
            # Muestra confirmación.
            messagebox.showinfo("Simulaciones finalizadas", "Se ejecutaron 10 simulaciones. Revise el archivo software_fj.log.")

            # Actualiza listas visuales.
            self.actualizar_listas()

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def actualizar_listas(self):
        # Actualiza listas visuales de clientes y reservas.

        # Limpia lista de clientes.
        self.lista_clientes.delete(0, tk.END)

        # Carga clientes.
        for cliente in self.sistema.clientes:
            # Inserta cliente.
            self.lista_clientes.insert(tk.END, cliente.mostrar_info())

        # Limpia lista de reservas.
        self.lista_reservas.delete(0, tk.END)

        # Carga reservas.
        for reserva in self.sistema.reservas:
            # Inserta reserva.
            self.lista_reservas.insert(tk.END, reserva.mostrar_info())

    def cargar_logs_gui(self):
        # Carga el contenido del archivo de logs en la interfaz.

        try:
            # Abre archivo de logs.
            with open("software_fj.log", "r", encoding="utf-8") as archivo:
                # Lee contenido.
                contenido = archivo.read()

        except FileNotFoundError:
            # Si no existe el log, muestra mensaje vacío.
            contenido = "El archivo de logs todavía no existe."

        except Exception as error:
            # Muestra error si no se puede leer.
            contenido = f"No fue posible cargar los logs: {error}"

        finally:
            # Limpia el área de logs.
            self.texto_logs.delete("1.0", tk.END)

            # Inserta contenido.
            self.texto_logs.insert(tk.END, contenido)


