        ttk.Label(frame, text="Servicio:").grid(row=0, column=0, sticky="w", padx=5, pady=5)

        # Opciones de servicios.
        self.opciones_servicios = [
            f"{servicio.identificador} - {servicio.nombre}"
            for servicio in self.sistema.servicios
        ]

