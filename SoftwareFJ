        ).pack(side="left", padx=5)

    def crear_reserva_gui(self):
        # Crea una reserva desde la interfaz.

        try:
            # Obtiene datos.
            documento = self.var_doc_reserva.get()
            nombre_servicio = self.var_servicio.get()

            # Convierte duración a entero.
            try:
                duracion = int(self.var_duracion.get())

            except ValueError as error:
                # Encadena excepción por conversión inválida.
                raise ReservaError("La duración debe ser un número entero.") from error

            # Busca cliente.
            cliente = self.sistema.obtener_cliente_por_documento(documento)

            # Busca servicio.
            servicio = None

            for item in self.sistema.servicios:
                if item.nombre == nombre_servicio:
                    servicio = item

            # Valida servicio.
            if servicio is None:
                raise ServicioNoDisponibleError("Debe seleccionar un servicio válido.")

            # Crea reserva.
            reserva = self.sistema.crear_reserva(cliente, servicio, duracion)

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado en GUI al crear reserva: {error}")
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Actualiza lista de reservas.
            self.actualizar_lista_reservas()

            # Limpia campos.
            self.var_doc_reserva.set("")
            self.var_duracion.set("")

            # Mensaje.
            messagebox.showinfo("Éxito", f"Reserva {reserva.identificador} creada correctamente.")

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def confirmar_reserva_gui(self):
        # Confirma la reserva seleccionada.

        try:
            # Obtiene selección.
            seleccion = self.lista_reservas.curselection()

            # Valida selección.
            if not seleccion:
                raise ReservaError("Debe seleccionar una reserva.")

            # Obtiene reserva.
            indice = seleccion[0]
            reserva = self.sistema.reservas[indice]

            # Confirma reserva.
            reserva.confirmar()

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado confirmando reserva desde GUI: {error}")
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Actualiza lista.
            self.actualizar_lista_reservas()

            # Mensaje.
            messagebox.showinfo("Éxito", "Reserva confirmada correctamente.")

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def cancelar_reserva_gui(self):
        # Cancela la reserva seleccionada.

        try:
            # Obtiene selección.
            seleccion = self.lista_reservas.curselection()

            # Valida selección.
            if not seleccion:
                raise ReservaError("Debe seleccionar una reserva.")

