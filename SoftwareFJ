    def agregar_cliente_gui(self):
        # Agrega un cliente desde la interfaz.

        try:
            # Llama al método del sistema.
            cliente = self.sistema.agregar_cliente(
                self.var_nombre.get(),
                self.var_documento.get(),
                self.var_telefono.get(),
                self.var_correo.get()
            )

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado en GUI al agregar cliente: {error}")
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Actualiza lista.
            self.actualizar_lista_clientes()

            # Limpia formulario.
            self.limpiar_campos_cliente()

            # Muestra mensaje.
            messagebox.showinfo("Éxito", f"Cliente {cliente.nombre} agregado correctamente.")

        finally:
            # Actualiza visor de logs.
            self.cargar_logs_gui()

    def seleccionar_cliente_gui(self, event):
        # Carga los datos del cliente seleccionado en el formulario.

        try:
            # Obtiene selección.
            seleccion = self.lista_clientes.curselection()

            # Si no hay selección, finaliza.
            if not seleccion:
                return

            # Obtiene índice seleccionado.
            indice = seleccion[0]

            # Obtiene cliente de la lista interna.
            cliente = self.sistema.clientes[indice]

            # Guarda documento actual para edición o eliminación.
            self.documento_cliente_seleccionado = cliente.documento

            # Carga datos en campos.
            self.var_nombre.set(cliente.nombre)
            self.var_documento.set(cliente.documento)
            self.var_telefono.set(cliente.telefono)
            self.var_correo.set(cliente.correo)

        except Exception as error:
            # Registra error.
            logging.error(f"Error seleccionando cliente desde GUI: {error}")
            messagebox.showerror("Error", "No fue posible seleccionar el cliente.")

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def editar_cliente_gui(self):
        # Edita el cliente seleccionado.

        try:
            # Valida que se haya seleccionado un cliente.
            if self.documento_cliente_seleccionado is None:
                raise ClienteInvalidoError("Debe seleccionar un cliente antes de editar.")

            # Edita cliente mediante el sistema.
            cliente = self.sistema.editar_cliente(
                self.documento_cliente_seleccionado,
                self.var_nombre.get(),
                self.var_documento.get(),
                self.var_telefono.get(),
                self.var_correo.get()
            )

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado en GUI al editar cliente: {error}")
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Actualiza clientes y reservas porque las reservas pueden mostrar datos del cliente editado.
            self.actualizar_lista_clientes()
            self.actualizar_lista_reservas()

            # Limpia formulario.
            self.limpiar_campos_cliente()

            # Muestra mensaje.
            messagebox.showinfo("Éxito", f"Cliente {cliente.nombre} editado correctamente.")

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def eliminar_cliente_gui(self):
        # Elimina el cliente seleccionado.

        try:
            # Valida que exista selección.
            if self.documento_cliente_seleccionado is None:
                raise ClienteInvalidoError("Debe seleccionar un cliente antes de eliminar.")

            # Solicita confirmación.
            confirmar = messagebox.askyesno(
                "Confirmar eliminación",
                "¿Está seguro de eliminar este cliente?"
            )

            # Si el usuario cancela, termina.
            if not confirmar:
                return

            # Elimina cliente.
            cliente = self.sistema.eliminar_cliente(self.documento_cliente_seleccionado)

        except SistemaFJError as error:
            # Muestra error controlado.
            messagebox.showerror("Error controlado", str(error))

        except Exception as error:
            # Registra error inesperado.
            logging.error(f"Error inesperado en GUI al eliminar cliente: {error}")
            messagebox.showerror("Error inesperado", str(error))

        else:
            # Actualiza lista.
            self.actualizar_lista_clientes()

            # Limpia formulario.
            self.limpiar_campos_cliente()

            # Muestra mensaje.
            messagebox.showinfo("Éxito", f"Cliente {cliente.nombre} eliminado correctamente.")

        finally:
            # Actualiza logs.
            self.cargar_logs_gui()

    def actualizar_lista_clientes(self):
        # Actualiza visualmente la lista de clientes.

        # Limpia lista.
        self.lista_clientes.delete(0, tk.END)

        # Inserta clientes actuales.
        for cliente in self.sistema.clientes:
