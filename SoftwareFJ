        ttk.Label(frame, text="Nuevo valor base:").grid(row=1, column=0, sticky="w", padx=5, pady=5)
        ttk.Entry(frame, textvariable=self.var_nuevo_precio, width=43).grid(row=1, column=1, padx=5, pady=5)

        # Botón actualizar.
        ttk.Button(
            frame,
            text="Actualizar valor",
            command=self.actualizar_valor_servicio_gui
        ).grid(row=2, column=0, columnspan=2, pady=10)

