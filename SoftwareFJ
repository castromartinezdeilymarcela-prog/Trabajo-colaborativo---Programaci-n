    def crear_pestana_logs(self):
        # Crea frame de logs.
        frame = ttk.LabelFrame(self.frame_logs, text="Archivo de logs .txt", padding=10)
        frame.pack(fill="both", expand=True, padx=10, pady=10)

        # Botón actualizar logs.
        ttk.Button(
            frame,
            text="Actualizar logs",
            command=self.cargar_logs_gui
        ).pack(pady=5)

        # Área de texto para logs.
        self.texto_logs = tk.Text(frame, height=30, wrap="word")
        self.texto_logs.pack(fill="both", expand=True)

    def cargar_logs_gui(self):
        # Carga el contenido del archivo de logs .txt.

        try:
            # Abre archivo de logs.
            with open("software_fj_log.txt", "r", encoding="utf-8") as archivo:
                contenido = archivo.read()

        except FileNotFoundError:
            # Mensaje si aún no existe el archivo.
            contenido = "El archivo software_fj_log.txt todavía no existe."

        except Exception as error:
            # Mensaje si ocurre error de lectura.
            contenido = f"No fue posible cargar los logs: {error}"

        finally:
            # Muestra contenido en la pestaña logs.
            self.texto_logs.delete("1.0", tk.END)
            self.texto_logs.insert(tk.END, contenido)


